# es-mini-agent — copy to .env and fill in real values. NEVER commit .env.

# Port this agent listens on. The Vercel proxy's RECORD_CONTROL_URL should
# resolve to http(s)://<this-mac-reachable-host>:PORT
PORT=8787

# Shared secret. MUST match RECORD_CONTROL_KEY set on Vercel for the es-os-app
# project. The agent refuses to start if this is unset.
RECORD_CONTROL_KEY=replace-me-with-a-long-random-string

# This Mini's building identity, e.g. "bench-1" for the bench-test Mac,
# or "bldg-42" for a real deployed unit. One Mini serves exactly one building.
# The agent refuses to start if this is unset.
BUILDING_ID=bench-1

# OBS control mode toggle. Leave empty to keep existing demo/mock behavior.
OBS_SOURCES=

# OBS websocket endpoint (obs-websocket v5 default).
OBS_WS_URL=ws://127.0.0.1:4455

# OBS websocket password. Leave empty if OBS auth is disabled.
OBS_WS_PASSWORD=

# Required only when OBS_SOURCES is set: base dir containing per-source folders.
OBS_RECORD_DIR=

# Optional R2 dummy-upload test settings (used by /r2test/* endpoints).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# Optional webhook sink for the upload_confirmed stub event payload.
UPLOAD_CONFIRMED_WEBHOOK_URL=
